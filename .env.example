# Copy to .env.local for local dev, or set these in the Vercel dashboard for deploys.
# Never commit real values.

# api/evaluate.js — Claude API key used to judge AIJudged escrow submissions
ANTHROPIC_API_KEY=

# api/upload.js — Vercel Blob read/write token, used to store escrow result files
BLOB_READ_WRITE_TOKEN=

# --- contracts/ (Foundry) ---
# Testnet-only key used to deploy ArcEscrowV2 via contracts/script/DeployV2.s.sol
# PRIVATE_KEY=

# --- agent/runner.mjs ---
# Testnet-only key for the autonomous agent's own wallet (must differ from the client wallet)
# AGENT_PRIVATE_KEY=
# ARC_ESCROW_ADDRESS=
# APP_BASE_URL=https://usdc-portal.vercel.app
# POLL_INTERVAL_MS=15000
